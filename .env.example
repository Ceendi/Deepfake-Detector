# Local development credentials. Copy to `.env` and adjust if needed.
# `.env` is gitignored - never commit real secrets.
# All passwords below are clearly marked dev-only and unsafe for any other use.

# === PostgreSQL =============================================================
POSTGRES_USER=deepfake
POSTGRES_PASSWORD=changeme_dev
POSTGRES_DB=deepfake
# POSTGRES_PORT=5432
# Database-per-service: the file-service gets its own DB + least-privilege user in the
# same Postgres container (created by infra/postgres/init on first/empty start).
# Password is interpolated into a SQL string literal — keep it apostrophe-free.
FILE_SERVICE_DB_NAME=fileservice
FILE_SERVICE_DB_USER=fileservice
FILE_SERVICE_DB_PASSWORD=changeme_dev_fsdb

# === Redis ==================================================================
REDIS_PASSWORD=changeme_dev
# REDIS_PORT=6379

# === RabbitMQ ===============================================================
RABBITMQ_USER=deepfake
RABBITMQ_PASSWORD=changeme_dev
# RABBITMQ_AMQP_PORT=5672
# RABBITMQ_UI_PORT=15672

# === Object Storage (SeaweedFS, S3-compatible) ==============================
# Names are vendor-neutral (S3_*) so swapping SeaweedFS for AWS S3, R2, or
# another backend later requires no app-side changes.
#
# Three identities, each scoped to specific buckets via infra/seaweedfs/s3.json:
#   - admin        (Admin)                                     - bucket creation only
#   - file-service (RW: deepfake-uploads)                      - upload pipeline
#   - detector     (R: deepfake-uploads, RW: analysis-artifacts) - ML services
S3_ADMIN_KEY=df-admin
S3_ADMIN_SECRET=changeme_dev_admin
S3_FILE_SERVICE_KEY=fs-key
S3_FILE_SERVICE_SECRET=changeme_dev_fs
S3_DETECTOR_KEY=det-key
S3_DETECTOR_SECRET=changeme_dev_det
# S3_PORT=8333
# S3_ENDPOINT_INTERNAL=http://seaweedfs:8333    # used by backend services in the docker network
# Host baked into presigned URLs (file-service). Must be reachable from the browser; the internal
# seaweedfs:8333 is not resolvable outside the docker network. Dev: localhost:8333.
STORAGE_PUBLIC_ENDPOINT=http://localhost:8333

# === Keycloak ===============================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_dev
KEYCLOAK_REALM=deepfake
KEYCLOAK_CLIENT_WEB=deepfake-web
# Dedicated Postgres for Keycloak (service `keycloak-db`, profile `auth`).
# Without persistent DB, dev users would vanish on every `compose down` —
# Postgres from day one keeps them across restarts.
KEYCLOAK_DB_PASSWORD=changeme_dev_kcdb
# KEYCLOAK_PORT=8180

# === Application config =====================================================
# Single, stable issuer URL. KC_HOSTNAME forces every token to carry this exact
# `iss`, so backend services validate against it (and the frontend redirects here).
# Dockerized backends fetch the signing keys over the docker network instead
# (JWK_SET_URI, set in docker-compose.yml — not a secret, so it lives only there).
# This value is the default backends use when run from the IDE.
JWT_ISSUER_URI=http://localhost:8180/realms/deepfake

# === Observability (OpenTelemetry tracing) ==================================
# Tracer is always on (traceId/spanId in logs). Only OTLP *export* is gated:
# keep it false for core-only dev, else the exporter spams a dead endpoint.
# Flip to true when running the `monitoring` profile (Tempo present) to see traces in Grafana.
OTEL_TRACING_EXPORT_ENABLED=false
OTEL_OTLP_ENDPOINT=http://tempo:4318/v1/traces

# === Observability stack (profile: monitoring) ==============================
# Grafana admin login (user: admin). Dev-only. UI at http://localhost:3000.
GF_SECURITY_ADMIN_PASSWORD=admin
# Host ports (all bound to 127.0.0.1). Uncomment to override.
# PROMETHEUS_PORT=9090
# LOKI_PORT=3100
# TEMPO_PORT=3200
# GRAFANA_PORT=3000
# ALLOY_PORT=12345

# === Backpressure (orchestrator) ============================================
# Max concurrent in-flight analyses before POST /api/analysis returns 429.
# Lower it (e.g. 2) to exercise backpressure with the fast dummy detectors.
BACKPRESSURE_MAX_INFLIGHT=20

# === Load test (D4 — file-service replication) ==============================
# Number of file-service replicas. Default 1; set 2 for the D4 comparison run.
# Same compose, no file edit between variants: FILE_SERVICE_REPLICAS=2 docker compose --profile core --profile auth up -d
# FILE_SERVICE_REPLICAS=1
